function Section({ title, children }) {
  return (
    <motion.section
      initial={{ opacity: 0, y: 50 }}
      whileInView={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.8 }}
      className="p-10 relative z-10"
    >
      <div className="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-6">
        <h2 className="text-2xl text-cyan-400 mb-4">{title}</h2>
        <div className="text-gray-300">{children}</div>
      </div>
    </motion.section>
  );
}

import { motion } from "framer-motion";
import Particles from "react-tsparticles";
import { useEffect, useRef } from "react";
import * as THREE from "three";

export default function Portfolio() {
  const mountRef = useRef(null);

  // 🌍 3D PLANETS SYSTEM
  useEffect(() => {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true });

    renderer.setSize(window.innerWidth, window.innerHeight);
    mountRef.current.appendChild(renderer.domElement);

    // Main planet
    const geometry = new THREE.SphereGeometry(2, 32, 32);
    const material = new THREE.MeshBasicMaterial({ color: 0x00f7ff, wireframe: true });
    const planet = new THREE.Mesh(geometry, material);
    scene.add(planet);

    // Orbiting small planet
    const smallGeo = new THREE.SphereGeometry(0.5, 32, 32);
    const smallMat = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true });
    const moon = new THREE.Mesh(smallGeo, smallMat);
    scene.add(moon);

    camera.position.z = 6;

    let angle = 0;

    const animate = () => {
      requestAnimationFrame(animate);

      planet.rotation.y += 0.01;

      angle += 0.02;
      moon.position.x = 3 * Math.cos(angle);
      moon.position.z = 3 * Math.sin(angle);

      renderer.render(scene, camera);
    };

    animate();

    return () => mountRef.current.removeChild(renderer.domElement);
  }, []);

  return (
    <div className="bg-black text-white min-h-screen overflow-x-hidden">
      {/* 3D BACKGROUND */}
      <div ref={mountRef} className="fixed top-0 left-0 w-full h-full z-0 opacity-30" />

      {/* PARTICLES */}
      <Particles
        options={{ particles: { number: { value: 60 }, move: { enable: true } } }}
        className="absolute z-0"
      />

      {/* HERO */}
      <section className="h-screen flex flex-col justify-center items-center text-center relative z-10">
        <motion.h1 className="text-6xl text-cyan-400 glow">ABHISHEK BHARTI</motion.h1>
        <p className="mt-4 text-gray-300">Cyberpunk Developer • UI Builder</p>
      </section>

      {/* DASHBOARD UI */}
      <section className="p-10 relative z-10">
        <div className="grid md:grid-cols-3 gap-6">
          {["HTML", "CSS", "JavaScript", "React"].map((skill, i) => (
            <motion.div
              key={i}
              whileHover={{ scale: 1.05 }}
              className="border border-cyan-400 p-4 text-center rounded"
            >
              {skill}
            </motion.div>
          ))}
        </div>
      </section>

      {/* PROJECTS */}
      <section className="p-10 relative z-10">
        <h2 className="text-3xl text-cyan-400 mb-6">Projects</h2>
        <div className="grid md:grid-cols-2 gap-6">
          {[
            "Portfolio Website",
            "Amazon Clone",
            "Landing Page"
          ].map((p, i) => (
            <motion.div
              key={i}
              whileHover={{ scale: 1.08 }}
              className="border border-cyan-400 p-6 rounded"
            >
              {p}
            </motion.div>
          ))}
        </div>
      </section>

      {/* CONTACT */}
      <section className="p-10 relative z-10">
        <h2 className="text-2xl text-cyan-400">Contact</h2>
        <p>Email: goswamiabhishek055@gmail.com</p>
        <p>Phone: 6390332507</p>
      </section>

      {/* AIRPLANE */}
      <div className="airplane text-3xl">✈️</div>

      <style>{`
        .glow { text-shadow: 0 0 20px #00f7ff; }
        .airplane {
          position: fixed;
          bottom: 20px;
          left: -100px;
          animation: fly 10s linear infinite;
        }
        @keyframes fly {
          0% { transform: translateX(-100px); }
          100% { transform: translateX(110vw); }
        }
      `}</style>
    </div>
  );
}
